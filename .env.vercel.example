# ============================================
# Heres Protocol — Vercel Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables
# <YOUR_...> 표시된 것만 직접 채우면 됩니다
# ============================================

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=AmiL7vEZ2SpAuDXzdxC3sJMyjZqgacvwvvQdT3qosmsW
NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=Covn3moA8qstPgXPgueRGMSmi94yXvuDCWTjQVBxHpzb

# --- Crank (auto-execute cron) ---
CRANK_WALLET_PRIVATE_KEY=<YOUR_CRANK_WALLET_PRIVATE_KEY>
CRON_SECRET=<YOUR_RANDOM_STRING>

# --- CRE: Mock mode (Vercel에서는 실제 Chainlink 없이 self-callback) ---
CHAINLINK_CRE_WEBHOOK_URL=https://<YOUR_VERCEL_DOMAIN>/api/mock/cre
CHAINLINK_CRE_SIGNING_SECRET=<YOUR_RANDOM_STRING>
CHAINLINK_CRE_CALLBACK_SECRET=<YOUR_RANDOM_STRING>
MOCK_CRE_AUTO_CALLBACK=true
MOCK_CRE_CALLBACK_BASE_URL=https://<YOUR_VERCEL_DOMAIN>
