# ============================================
# Heres Protocol — Vercel Production Environment
# Copy these to Vercel Dashboard > Settings > Environment Variables
# ============================================

# --- Solana (Required) ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=AmiL7vEZ2SpAuDXzdxC3sJMyjZqgacvwvvQdT3qosmsW
NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=Covn3moA8qstPgXPgueRGMSmi94yXvuDCWTjQVBxHpzb
NEXT_PUBLIC_HELIUS_API_KEY=            # optional: Helius RPC for better reliability

# --- Crank (Required for auto-execute cron) ---
CRANK_WALLET_PRIVATE_KEY=<YOUR_CRANK_WALLET_PRIVATE_KEY>
CRON_SECRET=<generate-random-string>   # Vercel cron auth + CRE dispatch fallback

# --- CRE / Chainlink (Required for Intent Statement delivery) ---
CHAINLINK_CRE_WEBHOOK_URL=            # Chainlink CRE workflow webhook (production URL)
CHAINLINK_CRE_API_KEY=                # optional: webhook auth bearer token
CHAINLINK_CRE_SIGNING_SECRET=         # optional: HMAC signing for outgoing webhooks
CHAINLINK_CRE_CALLBACK_SECRET=<set>   # REQUIRED in production: verifies incoming callbacks

# --- Optional ---
CRE_DISPATCH_SECRET=                  # separate dispatch API auth (falls back to CRON_SECRET)
OPS_ALERT_WEBHOOK_URL=                # Slack/Discord webhook for failure alerts

# ============================================
# DO NOT SET THESE ON VERCEL:
# - MOCK_CRE_AUTO_CALLBACK (dev only)
# - MOCK_CRE_FORCE_FAIL (dev only)
# - MOCK_CRE_CALLBACK_BASE_URL (dev only)
# - TEST_MNEMONIC (test only)
# ============================================
